   "source": [
    "K = int(input())\n",
    "stack = []\n",
    "\n",
    "for i in range(K):\n",
    "    num = int(input())\n",
    "    if num == 0:\n",
    "        stack.pop()\n",
    "    else:\n",
    "        stack.append(num)\n",
    "\n",
    "print(sum(stack))"
   ]
