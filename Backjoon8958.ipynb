   "source": [
    "T = int(input())\n",
    "\n",
    "for i in range(T):\n",
    "    s = input()\n",
    "    score = 0\n",
    "    streak = 0\n",
    "\n",
    "    for ch in s:\n",
    "        if ch == 'O':\n",
    "            streak += 1\n",
    "            score += streak\n",
    "        else:\n",
    "            streak = 0\n",
    "\n",
    "    print(score)\n"
   ]
  }
