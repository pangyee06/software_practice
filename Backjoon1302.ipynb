   "source": [
    "n = int(input())\n",
    "count = {}\n",
    "\n",
    "for _ in range(n):\n",
    "    book = input().strip()\n",
    "    count[book] = count.get(book, 0) + 1\n",
    "\n",
    "max_count = max(count.values())\n",
    "answer = min(book for book, c in count.items() if c == max_count)\n",
    "print(answer)"
   ]
  }
 ],
