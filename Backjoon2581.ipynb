##Backjoon2581

M = int(input())
N = int(input())

li = []

for i in range(M, N + 1):
    if i < 2:
        continue

    e = 0
    for j in range(2, i):
        if i % j == 0:
            e += 1
            break

    if e == 0:
        li.append(i)

if len(li) == 0:
    print(-1)
else:
    print(sum(li))
    print(li[0])
