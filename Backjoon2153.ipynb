word = input()
s = 0
for c in word:
    if c.islower():
        s += ord(c) - 96
    else:
        s += ord(c) - 38

def is_prime(n):
    if n < 2: return False
    for i in range(2, int(n**0.5)+1):
        if n % i == 0:
            return False
    return True

print("It is a prime word." if is_prime(s) else "It is not a prime word.")
