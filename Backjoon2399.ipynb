   "source": [
    "N = int(input())\n",
    "nums = list(map(int, input().split()))\n",
    "nums.sort()\n",
    "\n",
    "prefix_sum = 0\n",
    "answer = 0\n",
    "\n",
    "for i in range(N):\n",
    "    answer += nums[i] * i - prefix_sum\n",
    "    prefix_sum += nums[i]\n",
    "\n",
    "print(answer * 2)"
   ]
  }
 ],
