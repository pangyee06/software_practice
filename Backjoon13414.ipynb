   "source": [
    "\n",
    "k, l = map(int, input().split())\n",
    "order = {}\n",
    "\n",
    "for i in range(l):\n",
    "    student_id = input().strip()\n",
    "    order[student_id] = i\n",
    "\n",
    "result = sorted(order.items(), key=lambda x: x[1])\n",
    "\n",
    "for student_id, _ in result[:k]:\n",
    "    print(student_id)"
   ]
  }
