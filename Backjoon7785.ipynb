   "source": [
    "n = int(input())\n",
    "in_company = set()\n",
    "\n",
    "for_in range(n):\n",
    "    name, status = input().split()\n",
    "    if status == \"enter\":\n",
    "        in_company.add(name)\n",
    "    else:\n",
    "        in_company.discard(name)\n",
    "\n",
    "for name in sorted(in_company, reverse=True):\n",
    "    print(name)"
   ]
  }
