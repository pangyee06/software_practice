    "N = 5\n",
    "\n",
    "testgrade = []\n",
    "\n",
    "for i in range(N):\n",
    "    testgrade.append(int(input()))\n",
    "\n",
    "testgrade = [40 if i<40 else i for i in testgrade]\n",
    "\n",
    "total = sum(testgrade)\n",
    "\n",
    "average = total//5\n",
    "\n",
    "print(average)"
